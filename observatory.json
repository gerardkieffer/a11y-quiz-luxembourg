    "/audits": {
      "get": {
        "tags": [
          "audits"
        ],
        "summary": "Displays audits list",
        "description": "List of audits conducted by the Information and Press Service of the Luxembourg government.",
        "produces": [
          "application/json",
          "text/csv"
        ],
        "parameters": [
          {
            "name": "in",
            "in": "query",
            "description": "start year",
            "required": false,
            "type": "integer",
            "collectionFormat": "multi"
          },
          {
            "name": "out",
            "in": "query",
            "description": "end year",
            "required": false,
            "type": "integer",
            "collectionFormat": "multi"
          },
          {
            "name": "type",
            "in": "query",
            "description": "audit type: 1 (in-depth, default), 2 (app), 3 (simplified)",
            "required": false,
            "type": "array",
            "items": {
              "type": "integer",
              "enum": [
                1,
                2,
                3
              ],
              "default": 1
            },
            "collectionFormat": "multi"
          },
          {
            "name": "output",
            "in": "query",
            "description": "JSON (default) or CSV",
            "required": false,

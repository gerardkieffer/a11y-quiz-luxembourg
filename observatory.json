    "/statements_distribution": {
      "get": {
        "tags": [
          "statements"
        ],
        "summary": "Displays accessibility statements distribution",
        "description": "Distribution by administrative level: state; cities; others i.e. public law bodies, as defined in Article 2 d) of the amended law of April 8, 2018, on public procurement. The statements included are those that have been updated in the last three years.",
        "produces": [
          "application/json",
          "text/csv"
        ],
        "parameters": [
          {
            "name": "output",
            "in": "query",
            "description": "JSON (default) or CSV",

  "host": "observatoire.accessibilite.public.lu",
  "basePath": "/api/1",
  "tags": [
    {
      "name": "inventory",
      "description": "inventory of websites and apps of Luxembourg public service organizations"
    },
    {
      "name": "statements",
      "description": "accessibility statements of websites and apps of Luxembourg public service organizations"
    },
    {
      "name": "audits",
      "description": "audits assessing the accessibility of websites and apps of Luxembourg public service organizations"
    },
    {
      "name": "keyfigures",
      "description": "displays the number of websites and apps in the inventory and meeting the criteria for an audit, the number of statements and the number of audits"
    },
    {
      "name": "lastupdates",
      "description": "last audits published on the observatory"
    },
    {
      "name": "mediations",
      "description": "mediations provided by the Information and Press Service between users and public sector bodies on digital accessibility issues"
    },
    {
      "name": "labels",
      "description": "Digital accessibility awards"
    },
    {
      "name": "compliance",
      "description": "compliance by administrative level; main non-compliance issues"
    }
  ],
  "schemes": [
    "https", "http"
  ],
  "paths": {
    "/inventory": {
      "get": {
        "tags": [
          "inventory"
        ],
        "summary": "Displays inventory",
        "description": "Order by date, administrative level, theme, status (default: by item name). Only public online websites and apps are listed here.",
        "produces": [
          "application/json",
          "text/csv"
        ],
        "parameters": [
          {
            "name": "sort",
            "in": "query",
            "description": "Values that need to be considered for sorting (default: by item name)",
            "required": false,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "name",
                "date",
                "administrativelevel",
                "theme",
                "status"
              ],
              "default": "date"
            },
            "collectionFormat": "multi"
          },
          {
            "name": "output",
            "in": "query",
            "description": "JSON (default) or CSV",
            "required": false,
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "json",
                "csv"
              ],
              "default": "json"
            },
            "collectionFormat": "multi"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Inventory"
              }
            }
          },
          "400": {
            "description": "Bad request: invalid sorting / output value"
          }
        }
      }
    },
    "/inventory_distribution": {
      "get": {
        "tags": [
          "inventory"
        ],
        "summary": "Displays inventory distribution",
        "description": "Distribution by administrative level: state; cities; others i.e. public law bodies, as defined in Article 2 d) of the amended law of April 8, 2018, on public procurement.",
        "produces": [
          "application/json",
          "text/csv"
        ],
        "parameters": [
          {
            "name": "output",
            "in": "query",
            "description": "JSON (default) or CSV",

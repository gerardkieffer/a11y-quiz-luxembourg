  "info": {
    "description": "This page describes the behavior of the free and open API of this observatory.",
    "version": "1",
    "title": "Digital Accessibility Observatory Luxembourg",
    "termsOfService": "https://observatoire.accessibilite.public.lu/en/legalNotices",
    "contact": {
      "email": "accessibilite@sip.etat.lu"

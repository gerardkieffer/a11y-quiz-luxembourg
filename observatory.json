                "json",
                "csv"
              ],
              "default": "json"
            },
            "collectionFormat": "multi"
          }
        ],
        "responses": {
          "200": {
            "description": "successful operation",
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/Distribution"
              }
            }
          },
          "400": {
            "description": "Bad request: invalid output value"
          }
        }
      }
    },
